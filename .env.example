# ====================================================================
# 🌟 GOOGLE AI STUDIO CONFIGURATION
# ====================================================================
# 
# LangChain's ChatGoogleGenerativeAI natively detects either GEMINI_API_KEY or GOOGLE_API_KEY. We suggest providing GEMINI_API_KEY.
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# The active model we'll use when only one model is configured (backward compatible)
GEMINI_MODEL=gemini-2.5-flash

# Multi-model support (optional): comma-separated provider-prefixed refs.
# Auto-routing:
#   orchestration, navigation → strongest model (pro/flash/composer)
#   extraction, self_heal     → fastest model (flash-lite)
# Failover tries the next model on 503 / timeout.
#
# Examples:
# LLM_MODELS=google:gemini-3.1-flash-lite,google:gemini-3.5-flash
# LLM_MODELS=google:gemini-3.1-flash-lite,google:gemini-3.5-flash,cursor:composer-2.5
#
# When LLM_MODELS is unset, GEMINI_MODEL is used for all tasks.
# LLM_MODELS=gemini-3.1-flash-lite,gemini-3.5-flash

# Optional explicit task→model routing (JSON). Overrides auto-selection.
# Use the same refs as in LLM_MODELS (provider:model_id).
# LLM_TASK_ROUTING={"orchestration":"cursor:composer-2.5","navigation":"cursor:composer-2.5","extraction":"google:gemini-3.1-flash-lite","self_heal":"google:gemini-3.1-flash-lite"}

# ====================================================================
# 🤖 CURSOR AI (optional — native cursor-sdk, no proxy)
# ====================================================================
# Cursor models are NOT Google Gemini. They use the Cursor SDK directly.
# Wired for orchestration + navigation only (extraction/self_heal stay on Gemini).
#
# 1. Get CURSOR_API_KEY from Cursor Dashboard → Integrations
# 2. Add cursor:composer-2.5 (or cursor:gpt-5.5) to LLM_MODELS
#
# Runtime:
#   CURSOR_RUNTIME=local   — runs via SDK against CURSOR_WORKDIR (default: repo root)
#   CURSOR_RUNTIME=cloud   — requires CURSOR_CLOUD_REPO (Git URL for Cloud Agent VM)
#
# CURSOR_API_KEY=crsr_your_key_here
# CURSOR_RUNTIME=local
# CURSOR_WORKDIR=/path/to/NFE_Agent
# CURSOR_CLOUD_REPO=https://github.com/your-org/NFE_Agent
# CURSOR_DEFAULT_MODEL=composer-2.5

# LLM call safeguards
# Reasoning tasks (orchestration, navigation) use LLM_TIMEOUT_REASONING when set.
LLM_TIMEOUT_SECONDS=60
LLM_TIMEOUT_REASONING=120
LLM_MAX_RETRIES=1

# If langgraph dev still raises BlockingError on socket.connect, restart with:
#   langgraph dev --allow-blocking
# (Gemini's client uses sync HTTP; the app also sets blockbuster_skip around LLM calls.)

# Pull navigator prompts from LangSmith Hub (off by default — sync pulls block the event loop)
# USE_LANGSMITH_PROMPTS=false
# ====================================================================
# 🛠 LANGSMITH MONITORING CONFIGURATION
# ====================================================================
# 
# Tells LangChain to intercept call data and upload it to LangSmith
LANGCHAIN_TRACING_V2=true

# Your LangSmith API endpoint (defaults to the cloud-hosted version)
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# Paste your LangSmith API key here
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_key_here

# Define the project workspace where your agent traces will be grouped
LANGCHAIN_PROJECT="gemini-agent-learning"

# ====================================================================
# 📈 DYNATRACE / OPENTELEMETRY CONFIGURATION
# ====================================================================
# Dynatrace / OpenLLMetry OTLP endpoint (traces + correlated logs)
# Example: https://<env-id>.live.dynatrace.com/api/v2/otlp
TRACELOOP_BASE_URL=
# Dynatrace authorization headers (token needs openTelemetryTrace.ingest + logs.ingest scopes)
# Example: Authorization=Api-Token%20<your-token>
TRACELOOP_HEADERS=

# Alternative OpenTelemetry exporter configuration (falls back when TRACELOOP_* is unset)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Set to false to disable the legacy /api/v2/logs/ingest handler (OTLP logs remain enabled)
DYNATRACE_LOG_INGEST_ENABLED=true

# ====================================================================
# 🔌 PROJECT MCP SERVERS
# ====================================================================
# Single registry file for all MCP servers used by this LangGraph app.
# Default: config/mcp_servers.json  (edit that file to enable servers)
# MCP_SERVERS_CONFIG=

# Where generated k6 scripts / IR JSON are written for download
# NFE_ARTIFACTS_DIR=